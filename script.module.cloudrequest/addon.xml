<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="script.module.cloudrequest"
       name="CloudRequest"
       version="1.0.4"
       provider-name="oneplay team">

    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.requests"/>
    </requires>

    <extension point="xbmc.python.module" library="."/>

    <extension point="xbmc.addon.metadata">
        <summary lang="en">HTTP library with Cloudflare bypass</summary>
        <description lang="en">Provides a CloudScraper session with automatic bypass for Cloudflare IUAM challenges.</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
        </assets>
    </extension>

</addon>
